# EdRCF 6.0 — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs

# ── Supabase (persistance obligatoire sur Vercel serverless) ──────────────────
# Creer un projet sur supabase.com, puis executer dans SQL Editor :
#   CREATE TABLE edrcf_companies (
#     siren TEXT PRIMARY KEY,
#     data  JSONB NOT NULL,
#     score INT  DEFAULT 0,
#     updated_at TIMESTAMPTZ DEFAULT NOW()
#   );
# Settings -> API Keys -> Project URL + Secret key
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=sb_secret_your-key-here

# ── IA Copilot ────────────────────────────────────────────────────────────────
# OPTION 1 (recommande) : Vercel AI Gateway
# Une seule cle pour DeepSeek + Claude + Groq + OpenAI, avec cost tracking
# Creez une cle sur vercel.com/dashboard -> AI Gateway
AI_GATEWAY_API_KEY=vck_your-key-here

# OPTION 2 (fallback) : DeepSeek direct (~10 EUR/mois)
# Utilisee uniquement si AI_GATEWAY_API_KEY n'est pas definie
# DEEPSEEK_API_KEY=sk-your-key-here

# ── Sources donnees ───────────────────────────────────────────────────────────
# Papperclip v1 ne necessite aucune cle API.
# Les 25+ sources gouvernementales sont toutes gratuites et sans auth.
# API Recherche Entreprises : 7 req/s, aucune auth
# BODACC OpenDataSoft       : aucune auth, 48.8M annonces
# INSEE SIRENE              : OAuth2 gratuit (optionnel, pour bulk 25M)
# INPI RNE                  : compte gratuit, 10K req/jour (optionnel)

# ── INPI RNE (optionnel — donnees dirigeants enrichies) ──────────────────────
# Creer un compte gratuit sur : registre-national-entreprises.inpi.fr
# Limite : 10 000 req/jour
# INPI_USER=votre-email@exemple.com
# INPI_PASSWORD=votre-mot-de-passe
